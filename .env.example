# ============================================
# CONFIGURAÇÕES DO SISTEMA DE RH COM IA
# ============================================
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no Git!

# ---- OpenAI ----
# Obtenha sua chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Modelo a ser usado (gpt-4o-mini é mais barato; gpt-4o é mais preciso)
OPENAI_MODEL=gpt-4o-mini

# ---- Servidor ----
PORT=3000
NODE_ENV=development

# ---- Uploads ----
# Tamanho máximo do PDF em MB
MAX_FILE_SIZE_MB=10

# ---- Banco de Dados ----
DB_PATH=./backend/database/hr_system.db
